# AntiGravity Firebase Configuration Variables
# Rename this file to '.env' and populate with your actual Firebase API keys.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=queueless-d131e.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=queueless-d131e
VITE_FIREBASE_STORAGE_BUCKET=queueless-d131e.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

